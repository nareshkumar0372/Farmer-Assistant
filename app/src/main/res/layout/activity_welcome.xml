<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8F5E9"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center"
        android:layout_marginTop="20dp">

        <!-- Date & Time -->
        <TextView
            android:id="@+id/tvDateTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30dp"
            android:background="@drawable/date_background"
            android:elevation="6dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textColor="#1B5E20"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- App Icon -->
        <ImageView
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginBottom="12dp"
            android:src="@drawable/ic_farmer" />

        <!-- App Title -->
        <TextView
            android:text="Farmer Assistant"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Smart Farming Made Easy 🌾"
            android:textSize="16sp"
            android:textColor="#388E3C"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Modern Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:elevation="8dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Circular Profile Image -->
            <ImageView
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/circle_background"
                android:padding="4dp"
                android:scaleType="centerCrop"
                android:src="@drawable/my_photo1" />

            <!-- Name -->
            <TextView
                android:text="Nareshkumar R"
                android:textColor="#1B5E20"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- Register Number -->
            <TextView
                android:text="Register No: 23BIT0372"
                android:textColor="#555555"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- Project Title -->
            <TextView
                android:text="Project: Farmer Assistant"
                android:textColor="#2E7D32"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- Features -->
            <TextView
                android:text="✔ Sell products easily\n✔ Check market price\n✔ Buyer can buy crop efficiently"
                android:textColor="#444444"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginBottom="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Stylish Login Button -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/button_background"
                android:text="LOGIN"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>