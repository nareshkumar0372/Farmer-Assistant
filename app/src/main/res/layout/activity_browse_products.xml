<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#EDE7F6">

    <!-- ================= SAFE HEADER ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#5E35B1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="24dp"
        android:paddingBottom="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:elevation="12dp">

        <!-- Rounded Back Button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_circle_white"
            android:padding="14dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="#5E35B1"
            android:contentDescription="@string/back_desc"/>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/farm_products"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="20dp"/>
    </LinearLayout>


    <!-- ================= CONTENT ================= -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="18dp">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- FILTER CARD -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:padding="18dp"
                android:elevation="8dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_category"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#5E35B1"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <CheckBox
                        android:id="@+id/chkVegetable"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:text="@string/vegetable"
                        android:textStyle="bold"/>

                    <CheckBox
                        android:id="@+id/chkFruit"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:text="@string/fruit"
                        android:textStyle="bold"/>

                    <CheckBox
                        android:id="@+id/chkCereals"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:text="@string/cereals"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>


            <!-- PRODUCT SPINNER -->
            <Spinner
                android:id="@+id/spinnerProducts"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:background="#FFFFFF"
                android:padding="14dp"
                android:elevation="6dp"
                android:layout_marginBottom="24dp"/>


            <!-- PRODUCT DETAILS -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:padding="22dp"
                android:elevation="10dp"
                android:layout_marginBottom="30dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/product_details"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#5E35B1"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/tvDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="18dp"/>

                <ImageButton
                    android:id="@+id/btnSpeak"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:backgroundTint="#5E35B1"
                    android:padding="14dp"
                    android:src="@android:drawable/ic_btn_speak_now"
                    android:contentDescription="@string/speak_desc"/>
            </LinearLayout>


            <!-- ORDER BUTTON -->
            <Button
                android:id="@+id/btnOrder"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/order_now"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#5E35B1"
                android:elevation="8dp"/>
        </LinearLayout>

    </ScrollView>

</LinearLayout>